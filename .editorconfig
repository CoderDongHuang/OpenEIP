# EditorConfig — 编辑器统一配置
# http://editorconfig.org

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

# Java
[*.java]
indent_style = space
indent_size = 2
max_line_length = 120

# Python
[*.py]
indent_style = space
indent_size = 4
max_line_length = 120

# Frontend
[*.{ts,tsx,js,jsx,json,css,scss,html}]
indent_style = space
indent_size = 2
max_line_length = 120

# Markdown
[*.md]
indent_style = space
indent_size = 4
trim_trailing_whitespace = false

# YAML
[*.{yml,yaml}]
indent_style = space
indent_size = 2

# XML
[*.xml]
indent_style = space
indent_size = 4
