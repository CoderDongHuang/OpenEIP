# Auto detect text files and perform LF normalization
* text=auto

# Java
*.java text eol=lf diff=java
*.gradle text eol=lf
*.kts text eol=lf
*.properties text eol=lf
*.xml text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# Python
*.py text eol=lf diff=python
*.pyi text eol=lf

# Frontend
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.json text eol=lf
*.css text eol=lf
*.scss text eol=lf
*.html text eol=lf

# Documentation
*.md text eol=lf diff=markdown
*.mdx text eol=lf

# Shell
*.sh text eol=lf

# Binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.jar binary
*.war binary
