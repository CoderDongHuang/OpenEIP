{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openeip.dev/contracts/events/knowledge.embedding.completed.v1.schema.json",
  "title": "knowledge.embedding.completed v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["eventId", "eventType", "eventVersion", "timestamp", "source", "tenantId", "traceId", "payload"],
  "properties": {
    "eventId": { "type": "string", "format": "uuid" },
    "eventType": { "const": "knowledge.embedding.completed" },
    "eventVersion": { "const": 1 },
    "timestamp": { "type": "string", "format": "date-time" },
    "source": { "const": "python-engine-embedding" },
    "tenantId": { "type": "string", "minLength": 1, "maxLength": 64 },
    "traceId": { "type": "string", "minLength": 1, "maxLength": 128 },
    "payload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["knowledgeBaseId", "documentId", "chunkCount", "embeddingModel", "vectorDimension"],
      "properties": {
        "knowledgeBaseId": { "type": "string", "format": "uuid" },
        "documentId": { "type": "string", "format": "uuid" },
        "chunkCount": { "type": "integer", "minimum": 0, "maximum": 10000 },
        "embeddingModel": { "type": "string", "minLength": 1, "maxLength": 128 },
        "vectorDimension": { "type": "integer", "minimum": 1, "maximum": 65536 }
      }
    }
  }
}
