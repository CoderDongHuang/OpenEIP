FROM python:3.12.13-slim@sha256:57cd7c3a7a273101a6485ba99423ee568157882804b1124b4dd04266317710de

ARG PIP_INDEX_URL=https://pypi.org/simple
ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1

RUN groupadd --system openeip && useradd --system --gid openeip --create-home openeip
WORKDIR /app
COPY pyproject.toml ./
COPY requirements.lock ./
COPY engine-core/ engine-core/
RUN pip install --index-url "$PIP_INDEX_URL" -r requirements.lock \
    && pip install --no-deps .
USER openeip
EXPOSE 8000
CMD ["uvicorn", "engine_core.main:app", "--host", "0.0.0.0", "--port", "8000"]
